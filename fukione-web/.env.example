# Copy to .env and fill in real values. Never commit .env.
#
# Postgres (Neon). Use the POOLED endpoint (host contains ".pooler.neon.tech")
# for serverless/Vercel, and keep ?sslmode=require — Neon rejects non-SSL.
DATABASE_URL=postgres://USER:PASSWORD@HOST.pooler.neon.tech:5432/DBNAME?sslmode=require

# Payload secret — a long, random, unguessable string (used for hashing/encryption).
# Generate one with:  openssl rand -base64 32
PAYLOAD_SECRET=replace-with-a-long-random-string
